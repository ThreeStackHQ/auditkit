# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/auditkit"

# ── Auth (NextAuth v5) ────────────────────────────────────────────────────────
AUTH_SECRET="your-32-char-secret-here"   # openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_STARTER_PRICE_ID="price_..."      # Starter plan ($9/mo)
STRIPE_PRO_PRICE_ID="price_..."          # Pro plan ($19/mo)

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."

# ── Cron protection ───────────────────────────────────────────────────────────
CRON_SECRET="your-cron-secret"

# ── App URLs ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_WIDGET_URL="http://localhost:3001"
